# ============================================
# NexusOps — Production Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# Lines marked [REQUIRED] must be set before deployment.
# Lines marked [OPTIONAL] have sensible defaults.

# --- Application ---
APP_NAME=NexusOps                          # [REQUIRED]
APP_ENV=production                         # [REQUIRED]
APP_KEY=                                   # [REQUIRED] Run: php artisan key:generate
APP_DEBUG=false                            # [REQUIRED] Must be false in production
APP_URL=https://your-domain.com            # [REQUIRED] Your production URL
APP_TIMEZONE=America/New_York              # [OPTIONAL]

# --- Database (MySQL/Aurora) ---
DB_CONNECTION=mysql                        # [REQUIRED]
DB_HOST=your-rds-endpoint.amazonaws.com    # [REQUIRED]
DB_PORT=3306                               # [REQUIRED]
DB_DATABASE=nexus_ops                      # [REQUIRED]
DB_USERNAME=nexus_ops_user                 # [REQUIRED]
DB_PASSWORD=                               # [REQUIRED] Strong password

# --- Redis (ElastiCache/Upstash) ---
REDIS_HOST=your-redis-endpoint             # [REQUIRED]
REDIS_PASSWORD=                            # [REQUIRED] If auth enabled
REDIS_PORT=6379                            # [OPTIONAL]

# --- Cache / Queue / Session ---
CACHE_STORE=redis                          # [REQUIRED]
QUEUE_CONNECTION=redis                     # [REQUIRED]
SESSION_DRIVER=redis                       # [REQUIRED]
SESSION_ENCRYPT=true                       # [OPTIONAL] Recommended

# --- Email (choose one) ---
MAIL_MAILER=resend                         # [REQUIRED] Options: resend, ses, smtp, postmark
MAIL_FROM_ADDRESS=noreply@your-domain.com  # [REQUIRED]
MAIL_FROM_NAME=NexusOps                    # [OPTIONAL]

# If using Resend:
RESEND_API_KEY=                            # [REQUIRED if MAIL_MAILER=resend]

# If using AWS SES (uses AWS credentials below):
# MAIL_MAILER=ses

# If using SMTP:
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# --- AWS ---
AWS_ACCESS_KEY_ID=                         # [REQUIRED if using S3/SES/SQS]
AWS_SECRET_ACCESS_KEY=                     # [REQUIRED if using S3/SES/SQS]
AWS_DEFAULT_REGION=us-east-1               # [OPTIONAL]
AWS_BUCKET=nexus-ops-uploads               # [REQUIRED if using S3]

# --- Mapbox (3D Facility Map) ---
MAPBOX_TOKEN=                              # [REQUIRED] Get from mapbox.com/account

# --- Slack Notifications ---
SLACK_BOT_USER_OAUTH_TOKEN=                # [OPTIONAL] For Slack alerts
SLACK_BOT_USER_DEFAULT_CHANNEL=            # [OPTIONAL]

# --- Error Monitoring ---
SENTRY_LARAVEL_DSN=                        # [OPTIONAL] Get from sentry.io

# --- Logging ---
LOG_CHANNEL=stack                          # [OPTIONAL]
LOG_LEVEL=info                             # [OPTIONAL] Options: debug, info, warning, error

# --- File Storage ---
FILESYSTEM_DISK=s3                         # [OPTIONAL] Use 's3' for production, 'local' for dev

# --- Broadcasting (Real-time) ---
BROADCAST_CONNECTION=log                   # [OPTIONAL] Use 'reverb' or 'pusher' for WebSocket
